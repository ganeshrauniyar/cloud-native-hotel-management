# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/grand_horizon
# When running via docker-compose, the mongo service host is "mongo":
# MONGO_URI=mongodb://mongo:27017/grand_horizon

# ── Auth ──
# CHANGE THIS to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Default admin (created by the seed script) ──
ADMIN_EMAIL=admin@grandhorizon.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Administrator
